---
// Header-D: Barra lateral fixa (sidebar)
import siteConfig from '../data/siteConfig.json';
import { getAllPosts } from '../lib/posts';

const { name, menu: baseMenu = [] } = siteConfig;

// Buscar categorias REAIS do banco de dados (SSR)
const allPosts = await getAllPosts();
const realCategories = [...new Set(allPosts.map(p => p.category))].filter(Boolean);

// Injetar categorias reais no item "Blog" do menu
const menu = baseMenu.map((item: any) => {
  if (item.label.toLowerCase() === 'blog' || item.href === '/blog') {
    return {
      ...item,
      children: realCategories.length
        ? realCategories.map(cat => ({
            label: cat,
            href: `/categoria/${cat.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-')}`
          }))
        : undefined,
    };
  }
  return item;
});
---
<!-- Sidebar fixa -->
<aside class="fixed inset-y-0 left-0 w-56 bg-dark text-white flex flex-col z-[100] hidden lg:flex">
  <!-- Logo -->
  <div class="p-6 border-b border-white/10">
    <a href="/" class="flex flex-col gap-1 hover:opacity-80 transition-opacity">
      <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white text-lg font-black">
        {name.charAt(0).toUpperCase()}
      </div>
      <span class="font-bold text-lg mt-2">{name}</span>
    </a>
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto p-4 space-y-1">
    {menu.map((item: any) => (
      <div>
        <a
          href={item.href}
          class="flex items-center justify-between px-3 py-2.5 rounded-lg text-white/70 hover:text-white hover:bg-white/10 transition-all text-sm font-medium group"
        >
          {item.label}
          {item.children?.length ? (
            <svg class="w-4 h-4 opacity-30 group-hover:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          ) : null}
        </a>
        {item.children?.length ? (
          <div class="pl-4 ml-3 border-l border-white/5 space-y-0.5 mt-1 mb-2">
            {item.children.map((child: any) => (
              <a href={child.href} class="block px-3 py-1.5 text-xs text-white/40 hover:text-primary transition-colors">
                {child.label}
              </a>
            ))}
          </div>
        ) : null}
      </div>
    ))}
    <div class="pt-4 border-t border-white/10 mt-4">
      <a
        href="/blog"
        class="flex items-center justify-center px-3 py-2.5 bg-primary rounded-lg text-white text-sm font-semibold hover:opacity-90 transition-opacity"
      >
        Ver Blog
      </a>
    </div>
  </nav>
</aside>

<!-- Mobile header (para telas menores que lg) -->
<header class="lg:hidden sticky top-0 z-50 bg-dark text-white">
  <div class="px-4 flex items-center justify-between h-14">
    <a href="/" class="font-bold text-lg">{name}</a>
    <button id="menu-btn-d" class="p-2 rounded text-white/70 hover:text-white" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
  <div id="mobile-menu-d" class="hidden bg-dark/95 px-4 py-3 space-y-1 border-t border-white/10">
    {menu.map((item: any) => (
      <div>
        <a href={item.href} class="block py-2 text-sm font-medium text-white/80 hover:text-white">
          {item.label}
        </a>
        {item.children?.length ? (
          <div class="pl-4 space-y-1 mb-2">
            {item.children.map((child: any) => (
              <a href={child.href} class="block py-1 text-xs text-white/50 hover:text-primary">
                {child.label}
              </a>
            ))}
          </div>
        ) : null}
      </div>
    ))}
  </div>
</header>

<script>
  document.getElementById('menu-btn-d')?.addEventListener('click', () => {
    document.getElementById('mobile-menu-d')?.classList.toggle('hidden');
  });
</script>