---
// About-H: Expert Bio / Founder - Foco na autoridade pessoal
interface Stat { value: string; label: string; }
interface Props {
  title: string;
  desc: string;
  image: string;
  btnText: string;
  btnLink: string;
  stats: Stat[];
}
const { title, desc, image, btnText, btnLink } = Astro.props;
---
<section class="py-24 bg-white overflow-hidden">
  <div class="max-w-5xl mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20">
      
      <!-- Bio Image Left -->
      <div class="relative flex-shrink-0 group">
        <div class="w-64 h-64 md:w-80 md:h-80 rounded-full overflow-hidden border-8 border-gray-50 shadow-2xl relative z-10 transition-transform duration-700 hover:scale-105">
          <img src={image} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Specialist Profile" />
        </div>
        <!-- Decorative accents -->
        <div class="absolute -top-4 -left-4 w-24 h-24 bg-primary/10 rounded-full -z-0 animate-pulse"></div>
        <div class="absolute inset-0 rounded-full border-2 border-primary/20 scale-110 -z-0 border-dashed animate-spin-slow"></div>
      </div>

      <!-- Bio Text Right -->
      <div class="flex-1 text-center md:text-left">
        <span class="inline-block px-4 py-1.5 rounded-full bg-dark text-white text-[10px] font-black uppercase tracking-[0.3em] mb-6">
          Especialista Responsável
        </span>
        <h2 class="text-4xl md:text-5xl font-black text-dark tracking-tighter mb-6 leading-tight">
          {title}
        </h2>
        <p class="text-gray-500 leading-relaxed mb-8 font-medium italic md:text-lg">
          "{desc}"
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-6 justify-center md:justify-start">
           <a href={btnLink} class="px-8 py-3.5 bg-primary text-white font-black rounded-full hover:shadow-xl hover:shadow-primary/30 transition-all uppercase tracking-widest text-xs">
             {btnText}
           </a>
           <div class="flex items-center gap-4 border-l border-gray-100 pl-6">
              <span class="text-[10px] font-black text-gray-300 uppercase tracking-widest">Siga-me:</span>
              <a href="#" class="text-dark hover:text-primary transition-colors"><svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
           </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg) scale(1.1); }
    to { transform: rotate(360deg) scale(1.1); }
  }
  .animate-spin-slow {
    animation: spin-slow 12s linear infinite;
  }
</style>