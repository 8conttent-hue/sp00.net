---
// Hero-A: Full-width background image, texto centralizado
interface Props {
  title: string;
  subtitle: string;
  btnText: string;
  btnLink: string;
  bgImage: string;
}
const { title, subtitle, btnText, btnLink, bgImage } = Astro.props;
---
<section
  class="relative min-h-[70vh] flex items-center justify-center text-white"
  style={`background: url(${bgImage}) center/cover no-repeat`}
>
  <!-- Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-dark/70 via-dark/50 to-dark/80"></div>

  <!-- Content -->
  <div class="relative z-10 text-center max-w-3xl mx-auto px-4 py-20">
    <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary/90 bg-white/10 border border-white/20 px-4 py-1.5 rounded-full mb-6 backdrop-blur-sm">
      Portal de Conteúdo
    </span>
    <h1 class="text-4xl md:text-6xl font-black leading-tight mb-6">
      {title}
    </h1>
    <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-10 max-w-2xl mx-auto">
      {subtitle}
    </p>
    <a
      href={btnLink}
      class="inline-flex items-center gap-2 px-8 py-4 bg-primary hover:opacity-90 text-white font-bold text-base rounded-xl transition-opacity shadow-lg shadow-primary/30"
    >
      {btnText}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
</section>